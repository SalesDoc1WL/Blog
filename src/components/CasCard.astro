---
import { url } from '../lib/url.js';
const { cas } = Astro.props; // entry de la collection `cas`
const { data, slug } = cas;
const secteurLabels = {
  banque: 'Banque', 'secteur-public': 'Secteur public', assurance: 'Assurance',
  'protection-sociale': 'Protection sociale', courtage: 'Courtage', collectivites: 'Collectivités',
};
---
<a class="ref reveal" href={url(`/cas/${slug}`)}>
  <span class="tag">{secteurLabels[data.secteur] ?? data.secteur}</span>
  <h3>{data.titre}</h3>
  <p>{data.resume}</p>
  <span class="more arrow">Lire le cas </span>
</a>
